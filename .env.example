# QuickBooks OAuth credentials
# Get these from developer.intuit.com after registering your app
QBO_CLIENT_ID=your_client_id_here
QBO_CLIENT_SECRET=your_client_secret_here
QBO_REDIRECT_URI=https://your-railway-app.up.railway.app/auth/callback

# Set to 'sandbox' for testing, 'production' for live QBO data
QBO_ENVIRONMENT=production

# Random secret string for session encryption — generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_random_string

# Port (Railway sets this automatically)
PORT=3000
